FROM fedora:latest

RUN dnf install -y \
    nodejs npm \
    git curl which \
    golang \
    python3 python3-pip python3-devel \
    gcc gcc-c++ make cmake \
    rust cargo \
    java-latest-openjdk-devel maven \
    jq ripgrep fd-find \
    diffutils patch unzip procps-ng \
    && dnf clean all

# Install Google Cloud SDK
RUN curl -fsSL https://sdk.cloud.google.com | bash -s -- --disable-prompts --install-dir=/opt \
    && ln -s /opt/google-cloud-sdk/bin/gcloud /usr/local/bin/gcloud \
    && ln -s /opt/google-cloud-sdk/bin/gsutil /usr/local/bin/gsutil

# Install Aikido safe-chain before any npm installs
RUN curl -fsSL https://github.com/AikidoSec/safe-chain/releases/latest/download/install-safe-chain.sh | sh

RUN bash -c 'source /root/.safe-chain/scripts/init-posix.sh && npm install -g \
    @anthropic-ai/claude-code \
    @google/gemini-cli \
    @openai/codex \
    opencode-ai'

COPY entrypoint.sh /usr/local/bin/entrypoint.sh
RUN useradd -m -s /bin/bash user
USER user
WORKDIR /workspace
ENTRYPOINT ["entrypoint.sh"]
